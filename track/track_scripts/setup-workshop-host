#!/bin/bash
set -euxo pipefail

# ─── Python 3.11 ──────────────────────────────────────────────────────────────
apt-get update && apt-get install -y --no-install-recommends \
    wget curl git vim nano unzip ca-certificates bash-completion \
    software-properties-common fontconfig

add-apt-repository ppa:deadsnakes/ppa -y
apt-get update && apt-get install -y python3.11 python3.11-venv python3-pip
update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
update-alternatives --install /usr/bin/python  python  /usr/bin/python3.11 1

python --version

# ─── Temporal CLI ─────────────────────────────────────────────────────────────
curl -sSf https://temporal.download/cli.sh | sh
chmod +x /root/.temporalio/bin/temporal
ln -sf /root/.temporalio/bin/temporal /usr/local/bin/temporal
export PATH=$PATH:/root/.temporalio/bin:/usr/local/bin
echo 'export PATH=$PATH:/root/.temporalio/bin:/usr/local/bin' >> /root/.bashrc

temporal --version

# ─── Temporal server (systemd service) ────────────────────────────────────────
mkdir -p /workspace/exercise

cat > /etc/systemd/system/temporal-server.service <<'EOF'
[Unit]
Description=Temporal Dev Server
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/temporal server start-dev \
    --ui-port 8080 \
    --ip 0.0.0.0 \
    --db-filename /workspace/temporal.db
Restart=on-failure
RestartSec=5
StandardOutput=append:/workspace/temporal.log
StandardError=append:/workspace/temporal.log

[Install]
WantedBy=multi-user.target
EOF

systemctl enable temporal-server
systemctl start temporal-server

# Wait for Temporal server to be healthy
echo "Waiting for Temporal server..."
for i in $(seq 1 30); do
    if temporal operator cluster health --address 127.0.0.1:7233 2>/dev/null | grep -q SERVING; then
        echo "Temporal server healthy."
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "ERROR: Temporal server failed to become healthy"
        exit 1
    fi
    sleep 3
done

# ─── Pull agents image (used for code-server, pip cache, and exercises) ───────
docker pull ghcr.io/mmerrell/temporal-python-agents-sandbox:latest
docker create --name tmp-sandbox ghcr.io/mmerrell/temporal-python-agents-sandbox:latest

# ─── code-server ──────────────────────────────────────────────────────────────
# Install the native binary (fast), copy extension data from image (no download)
curl -fsSL https://code-server.dev/install.sh | sh

mkdir -p /root/.local/share/code-server
docker cp tmp-sandbox:/root/.local/share/code-server /root/.local/share/

cat > /root/.local/share/code-server/User/settings.json <<'EOF'
{
    "workbench.colorTheme": "Default Dark+",
    "workbench.startupEditor": "none",
    "security.workspace.trust.enabled": false,
    "editor.fontSize": 14,
    "editor.tabSize": 4,
    "python.defaultInterpreterPath": "/usr/bin/python3.11",
    "workbench.activityBar.visible": false,
    "workbench.secondarySideBar.visible": false,
    "workbench.statusBar.visible": true,
    "editor.suggestOnTriggerCharacters": true
}
EOF

cat > /etc/systemd/system/code-server.service <<'EOF'
[Unit]
Description=Code Server
After=network.target

[Service]
Type=simple
Restart=always
RestartSec=1
User=root
ExecStart=/usr/bin/code-server --host 0.0.0.0 --port 8443 --cert --auth none /workspace/exercise

[Install]
WantedBy=multi-user.target
EOF

systemctl enable code-server
systemctl start code-server

# Wait for code-server to be ready
echo "Waiting for code-server..."
for i in $(seq 1 30); do
    if curl -sfk https://localhost:8443 > /dev/null 2>&1; then
        echo "code-server healthy."
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "ERROR: code-server failed to start on port 8443"
        exit 1
    fi
    sleep 2
done

# ─── Exercise code ────────────────────────────────────────────────────────────
docker cp tmp-sandbox:/opt/exercises /workspace/exercises

# ─── Python dependencies (install from cached wheels — no network downloads) ──
docker cp tmp-sandbox:/opt/pip-cache /opt/pip-cache
docker rm tmp-sandbox

pip install \
    --no-index \
    --find-links /opt/pip-cache \
    --ignore-installed \
    temporalio \
    "temporalio[openai-agents]" \
    openai-agents \
    openai \
    httpx \
    pydantic \
    python-dotenv \
    rich

# ─── Shell environment ─────────────────────────────────────────────────────────
cat >> /root/.bashrc <<'EOF'

export TEMPORAL_ADDRESS="127.0.0.1:7233"
export OPENAI_API_KEY="${OPENAI_API_KEY}"
alias tl="temporal workflow list"
alias rw="python run_worker.py"
alias rs="python run_starter.py"
EOF

# ─── Health checks ────────────────────────────────────────────────────────────
echo "Running health checks..."

temporal operator cluster health --address 127.0.0.1:7233 | grep -q SERVING \
    || { echo "ERROR: Temporal server not healthy"; exit 1; }

curl -sf http://localhost:8080 > /dev/null \
    || { echo "ERROR: Temporal UI not responding on port 8080"; exit 1; }

curl -sfk https://localhost:8443 > /dev/null \
    || { echo "ERROR: code-server not responding on port 8443"; exit 1; }

python -c "import temporalio, agents" \
    || { echo "ERROR: Python SDK imports failed"; exit 1; }

[ -d /workspace/exercises/02-building-from-scratch ] \
    || { echo "ERROR: Exercise directories not found"; exit 1; }

echo "All health checks passed. Track setup complete."
