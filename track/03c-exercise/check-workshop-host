#!/bin/bash
set -euo pipefail

echo "Checking workflow.py for Temporal OpenAI Agents integration..."

EXERCISE=/workspace/exercise/workflow.py

grep -q "@workflow.defn" "$EXERCISE" \
    || { fail-message "Missing @workflow.defn on the workflow class."; exit 1; }

grep -q "@workflow.run" "$EXERCISE" \
    || { fail-message "Missing @workflow.run on the run() method."; exit 1; }

grep -q "activity_as_tool" "$EXERCISE" \
    || { fail-message "Missing activity_as_tool() calls. Wrap your activities using openai_agents.workflow.activity_as_tool()."; exit 1; }

grep -q "agent = None" "$EXERCISE" \
    && { fail-message "Still have 'agent = None' — replace it with an Agent() definition."; exit 1; }

echo "Checking for a completed WeatherAgentWorkflow..."

COMPLETED=$(temporal workflow list \
    --namespace default \
    --query 'WorkflowType="WeatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "WeatherAgentWorkflow" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail-message "No completed WeatherAgentWorkflow found. Run the agent and check the Temporal UI."
    exit 1
fi

echo "All checks passed!"
