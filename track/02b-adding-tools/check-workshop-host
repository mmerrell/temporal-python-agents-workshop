#!/bin/bash
set -euo pipefail

echo "Checking for a completed WeatherAgentWorkflow with geo tools..."

# Look for a workflow that ran the distance query (requires chaining)
COMPLETED=$(temporal workflow list \
    --namespace default \
    --query 'WorkflowType="WeatherAgentWorkflow" AND ExecutionStatus="Completed"' \
    2>/dev/null | grep -c "WeatherAgentWorkflow" || true)

if [ "$COMPLETED" -lt 1 ]; then
    fail-message "No completed WeatherAgentWorkflow found. Run: python run_starter.py \"How far is it from San Francisco to Los Angeles?\""
    exit 1
fi

echo "Check passed!"
