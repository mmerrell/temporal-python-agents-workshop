# temporal-python-sandbox
# Base image for Temporal Python SDK labs (Instruqt).
#
# Contains:
#   - Python 3.11
#   - Temporal CLI (pinned)
#   - temporalio SDK
#   - Common dev tools (httpx, pydantic, python-dotenv)
#   - code-server (VS Code in browser) with Python extension pre-installed
#
# Does NOT contain agent-framework packages (openai-agents, openai, etc.).
# Those live in Dockerfile.agents, which extends this image.
#
# Temporal server is NOT run inside this image — it runs as a systemd
# service on the Instruqt VM host (instruqt/docker-28-3) via the track
# setup script. This image is for the learner's exercise sandbox only.

FROM python:3.11-slim-bookworm

# ─── System packages ──────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    vim \
    nano \
    less \
    unzip \
    ca-certificates \
    bash-completion \
    fontconfig \
    && rm -rf /var/lib/apt/lists/*

# ─── Temporal CLI ─────────────────────────────────────────────────────────────
ARG TEMPORAL_CLI_VERSION=1.3.0
RUN curl -sSL \
    "https://github.com/temporalio/cli/releases/download/v${TEMPORAL_CLI_VERSION}/temporal_cli_${TEMPORAL_CLI_VERSION}_linux_amd64.tar.gz" \
    | tar -xz -C /usr/local/bin temporal \
    && chmod +x /usr/local/bin/temporal

# ─── Python base dependencies ─────────────────────────────────────────────────
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir \
        temporalio \
        httpx \
        pydantic \
        python-dotenv \
        rich

# ─── code-server (VS Code in browser) ─────────────────────────────────────────
# Baked into the image so sandbox provisioning doesn't need to download it.
RUN curl -fsSL https://code-server.dev/install.sh | sh

# Pre-install the Python extension so it's available immediately on first load.
RUN code-server --install-extension ms-python.python

# Default VS Code settings — activity bar and secondary sidebar hidden for
# a cleaner learner experience.
RUN mkdir -p /root/.local/share/code-server/User
COPY docker/code-server-settings.json /root/.local/share/code-server/User/settings.json

# ─── Shell environment ────────────────────────────────────────────────────────
RUN echo 'export TEMPORAL_ADDRESS="${TEMPORAL_ADDRESS:-127.0.0.1:7233}"' >> /root/.bashrc \
    && echo 'alias tl="temporal workflow list"' >> /root/.bashrc

WORKDIR /workspace

CMD ["/bin/bash"]
