# temporal-python-agents-sandbox
# Extends temporal-python-sandbox with AI agent framework dependencies.
#
# Contains everything in Dockerfile.base plus:
#   - openai-agents (OpenAI Agents SDK)
#   - openai
#   - All four exercise directories baked into /opt/exercises/
#
# OPENAI_API_KEY is injected at runtime by the Instruqt environment config —
# it is never baked into this image.

FROM ghcr.io/mmerrell/temporal-python-sandbox:latest

# ─── Agent framework dependencies ─────────────────────────────────────────────
RUN pip install --no-cache-dir \
    openai-agents \
    openai

# ─── Exercise source code ─────────────────────────────────────────────────────
# Exercises are added here as they are built. The COPY is gated on the
# existence of actual files — empty directories are not enough for Docker COPY.
# Scaffold the directory structure so docker cp in setup-workshop-host works
# even before exercise files exist.
RUN mkdir -p \
    /opt/exercises/01-scratch-agent/practice \
    /opt/exercises/01-scratch-agent/solution \
    /opt/exercises/02-sdk-agent/practice \
    /opt/exercises/02-sdk-agent/solution \
    /opt/exercises/03-hitl-agent/practice \
    /opt/exercises/03-hitl-agent/solution \
    /opt/exercises/04-multi-agent/practice \
    /opt/exercises/04-multi-agent/solution

# Uncomment and add real files as exercises are built:
# COPY exercises/ /opt/exercises/

# ─── Shell conveniences ───────────────────────────────────────────────────────
RUN echo 'alias rw="python run_worker.py"' >> /root/.bashrc \
    && echo 'alias rs="python run_starter.py"' >> /root/.bashrc

WORKDIR /workspace

CMD ["/bin/bash"]
