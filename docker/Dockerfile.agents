# temporal-python-agents-sandbox
# Extends temporal-python-sandbox with AI agent framework dependencies.
#
# Contains everything in Dockerfile.base plus:
#   - openai-agents (OpenAI Agents SDK)
#   - openai
#   - temporalio[openai-agents] (Temporal + OpenAI Agents integration)
#   - Exercise directories baked into /opt/exercises/
#
# OPENAI_API_KEY is injected at runtime by the Instruqt environment config —
# it is never baked into this image.

FROM ghcr.io/mmerrell/temporal-python-sandbox:latest

# ─── Agent framework dependencies ─────────────────────────────────────────────
RUN pip install --no-cache-dir \
    openai-agents \
    openai \
    "temporalio[openai-agents]"

# ─── Exercise source code ─────────────────────────────────────────────────────
COPY exercises/02-building-from-scratch /opt/exercises/02-building-from-scratch
COPY exercises/03-agent-sdks /opt/exercises/03-agent-sdks

# Scaffold future exercise directories so docker cp works before they have files.
RUN mkdir -p \
    /opt/exercises/04-hitl/practice \
    /opt/exercises/04-hitl/solution \
    /opt/exercises/05-multi-agent/practice \
    /opt/exercises/05-multi-agent/solution

# ─── Shell conveniences ───────────────────────────────────────────────────────
RUN echo 'alias rw="python run_worker.py"' >> /root/.bashrc \
    && echo 'alias rs="python run_starter.py"' >> /root/.bashrc

WORKDIR /workspace

CMD ["/bin/bash"]
